{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://deepiri.ai/schemas/log-event.json",
  "title": "DeepiriLogEvent",
  "type": "object",
  "required": [
    "timestamp",
    "level",
    "service_name",
    "version",
    "trace_id",
    "message",
    "context"
  ],
  "additionalProperties": false,
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "level": {
      "type": "string",
      "enum": ["DEBUG", "INFO", "WARNING", "ERROR", "CRITICAL"]
    },
    "service_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "trace_id": {
      "type": "string",
      "minLength": 1
    },
    "message": {
      "type": "string"
    },
    "context": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
